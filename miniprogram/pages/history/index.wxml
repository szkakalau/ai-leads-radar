<scroll-view scroll-y class="page container" bindscrolltolower="onReachBottom">
  <view class="page-header"><text class="header-title">历史日报</text></view>

  <view wx:if="{{!isMember}}" class="paywall-full" style="text-align:center;padding:80rpx 40rpx">
    <text style="font-size:64rpx;display:block;margin-bottom:20rpx">🔒</text>
    <text style="font-size:30rpx;font-weight:600;display:block;margin-bottom:12rpx">会员专享内容</text>
    <text style="font-size:26rpx;color:var(--text-secondary);display:block;margin-bottom:32rpx">开通会员查看历史日报</text>
    <view class="btn-primary" bindtap="onGoMember" style="display:inline-block">立即开通</view>
  </view>

  <block wx:elif="{{list.length > 0}}">
    <view class="card" wx:for="{{list}}" wx:key="id" bindtap="onItemTap" data-date="{{item.date}}">
      <text style="font-size:30rpx;font-weight:600;display:block;margin-bottom:6rpx">{{item.date}}</text>
      <text style="font-size:24rpx;color:var(--text-secondary)">{{item.summary}}</text>
    </view>
    <view wx:if="{{loading}}" style="text-align:center;padding:20rpx;color:var(--text-hint)">加载中...</view>
    <view wx:if="{{!hasMore && list.length > 0}}" style="text-align:center;padding:20rpx;color:var(--text-hint)">— 已加载全部 —</view>
  </block>
</scroll-view>
