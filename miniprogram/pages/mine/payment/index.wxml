<scroll-view scroll-y class="page container" wx:if="{{plan}}">
  <view class="card" style="text-align:center">
    <text style="font-size:34rpx;font-weight:600;display:block">{{plan.name}}</text>
    <text style="font-size:48rpx;font-weight:700;color:var(--primary);display:block;margin:16rpx 0">{{plan.price}}元/月</text>
    <text style="font-size:24rpx;color:var(--text-secondary)">{{plan.desc}}</text>
  </view>

  <view wx:if="{{!submitted}}">
    <view class="card" style="text-align:center">
      <text style="font-size:28rpx;font-weight:600;display:block;margin-bottom:16rpx">扫码付款</text>
      <image src="{{qrcodeUrl || '/images/qrcode-placeholder.png'}}" mode="widthFix" style="width:400rpx;margin:0 auto;display:block"></image>
      <text style="font-size:22rpx;color:var(--text-hint);display:block;margin-top:12rpx">长按识别付款，备注您的微信号</text>
    </view>

    <view class="card">
      <text style="font-size:28rpx;font-weight:600;display:block;margin-bottom:16rpx">上传付款凭证</text>
      <view bindtap="onChooseVoucher" style="border:2rpx dashed var(--divider);border-radius:12rpx;padding:40rpx;text-align:center;min-height:160rpx;display:flex;align-items:center;justify-content:center">
        <image wx:if="{{voucherPath}}" src="{{voucherPath}}" mode="aspectFit" style="max-width:100%;max-height:300rpx"></image>
        <text wx:else style="color:var(--text-hint)">点击上传付款截图</text>
      </view>
      <input placeholder="填写您的联系微信号" value="{{contactWechat}}" bindinput="onContactInput" style="border:1rpx solid var(--divider);border-radius:8rpx;padding:20rpx;margin-top:20rpx;font-size:28rpx;width:100%"></input>
    </view>

    <view class="btn-primary" bindtap="onSubmit" style="margin-top:24rpx">
      <text>{{uploading ? '提交中...' : '提交审核'}}</text>
    </view>
  </view>

  <view wx:else class="card" style="text-align:center">
    <text style="font-size:64rpx;display:block;margin-bottom:16rpx">✅</text>
    <text style="font-size:32rpx;font-weight:600;display:block;margin-bottom:12rpx">提交成功</text>
    <text style="font-size:26rpx;color:var(--text-secondary);line-height:1.8">我们会尽快审核，审核通过后自动开通会员权限，一般10分钟内完成</text>
  </view>
</scroll-view>
