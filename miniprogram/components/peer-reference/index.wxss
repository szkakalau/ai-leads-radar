.peer-reference { position: relative; overflow: hidden; }
.section-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; color: var(--text-primary); }
.peer-item { padding: 16rpx 0; }
.peer-item + .peer-item { border-top: 1rpx solid var(--divider); }
.peer-nickname { font-size: 24rpx; color: var(--primary); font-weight: 500; margin-right: 8rpx; }
.peer-topic { font-size: 28rpx; font-weight: 600; display: block; margin: 8rpx 0; }
.peer-logic, .peer-reuse { font-size: 24rpx; color: var(--text-secondary); margin-top: 6rpx; }
.logic-label, .reuse-label { font-weight: 500; color: var(--text-primary); }
.blurred .peer-list { filter: blur(4px); pointer-events: none; }
.paywall-overlay { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(26, 35, 126, 0.9); color: #fff; padding: 20rpx 40rpx; border-radius: 12rpx; z-index: 10; }
.paywall-text { font-size: 26rpx; font-weight: 500; }
